<?xml version="1.0"?>
<robot name="ur5_like">
  <material name="blue"><color rgba="0.18 0.36 0.78 1"/></material>
  <material name="gray"><color rgba="0.55 0.57 0.60 1"/></material>
  <material name="dark"><color rgba="0.15 0.15 0.18 1"/></material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><cylinder radius="0.11" length="0.07"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><cylinder radius="0.11" length="0.07"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <mass value="5"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.07" length="0.16"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.07" length="0.16"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <mass value="3"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.2125 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.055" length="0.425"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.2125 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.055" length="0.425"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.2125 0 0" rpy="0 0 0"/>
      <mass value="5"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.196 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.047" length="0.392"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0.196 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.047" length="0.392"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.196 0 0" rpy="0 0 0"/>
      <mass value="3"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <link name="wrist_1_link">
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.13"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.13"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="wrist_2_link">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.11"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.11"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <link name="wrist_3_link">
    <visual>
      <origin xyz="0.045 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.035" length="0.09"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.045 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.035" length="0.09"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.045 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.035"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.035"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.089159" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="150" velocity="3.15"/>
  </joint>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.13585" rpy="0 1.57079632679 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="150" velocity="3.15"/>
  </joint>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.425 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="150" velocity="3.15"/>
  </joint>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="0.39225 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="50" velocity="3.2"/>
  </joint>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 0 0.10915" rpy="0 1.57079632679 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="50" velocity="3.2"/>
  </joint>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0 0.09465" rpy="0 1.57079632679 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="50" velocity="3.2"/>
  </joint>

  <joint name="tool0_fixed" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="tool0"/>
    <origin xyz="0.0823 0 0" rpy="0 0 0"/>
  </joint>
</robot>
